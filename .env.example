# ============================================
# Preet AI - Environment Variables
# Copy this to .env and fill in your values.
# ============================================

# Required: Node environment
NODE_ENV=production

# Required: Port the server listens on
PORT=3000

# Required: Self-hosted Supabase credentials
SUPABASE_URL=https://your-supabase-instance.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Required: Frontend Vite build needs these for the client bundle
VITE_SUPABASE_URL=https://your-supabase-instance.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Required: CORS allowed origins (comma-separated)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Required: App URL (used for public booking links, OAuth callbacks)
APP_URL=https://yourdomain.com

# Required: Gemini API key for AI features
GEMINI_API_KEY=your-gemini-api-key

# Optional: OpenAI API key (alternative AI provider)
OPENAI_API_KEY=

# Optional: S3-compatible storage (for file uploads)
# Set STORAGE_DRIVER=s3 to use S3, or leave unset for local disk fallback
AWS_S3_BUCKET=your-bucket-name
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Optional: SMTP email settings (for notifications & invites)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@yourdomain.com

# Optional: Stripe payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: Resend (alternative email provider)
RESEND_API_KEY=
